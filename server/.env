PORT=8080
APP_ENV=development
ETH_RPC_URL=https://eth.llamarpc.com

# Enable DB integration and auto-migration
DB_ENABLED=false
POSTGRES_DSN=host=localhost user=chainsight password=chainsight dbname=chainsight port=5432 sslmode=disable TimeZone=UTC
DB_AUTO_MIGRATE=true

# Background indexer
INDEXER_ENABLED=false
INDEXER_INITIAL_LOOKBACK=20
INDEXER_MAX_BLOCKS_PER_TICK=1
INDEXER_INTERVAL_SECONDS=8
